# --- Law 5: NO images/video in git, ever. This is a hard safety net. ---
*.jpg
*.jpeg
*.png
*.bmp
*.tif
*.tiff
*.mp4
*.avi
*.mov
*.mkv
*.webm
# Dataset archives live under DVC: the `data/raw/*.dvc` pointer files ARE tracked,
# but the archives themselves are cached by DVC and ignored via DVC's own per-target
# .gitignore. These extension rules are a belt-and-suspenders guard so a raw archive
# can never slip into git even before `dvc add` runs.
*.zip
*.tar
*.tar.gz
*.tgz

# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/

# Tooling caches
.ruff_cache/
.mypy_cache/
.pytest_cache/

# ML / experiment artifacts
mlruns/
*.pt
*.onnx
*.engine

# DVC caches (pointers .dvc files ARE tracked; cache is not)
/.dvc/cache
/.dvc/tmp

# OS
.DS_Store
